POSTGRES_PASSWORD=postgres
POSTGRES_USER=postgres
POSTGRES_DB=postgres
# PostgreSQL runtime tuning (optional overrides).
POSTGRES_MAX_CONNECTIONS=150
POSTGRES_SHARED_BUFFERS=512MB
POSTGRES_EFFECTIVE_CACHE_SIZE=2GB
POSTGRES_WORK_MEM=8MB
POSTGRES_MAINTENANCE_WORK_MEM=128MB
POSTGRES_MAX_WAL_SIZE=2GB

JWT_SECRET=
ANON_KEY=
SERVICE_ROLE_KEY=
REALTIME_DB_ENC_KEY=supabaserealtime
REALTIME_DB_USER=supabase_admin

SITE_URL=http://localhost:5173
URI_ALLOW_LIST=http://localhost:5173/*
API_EXTERNAL_URL=http://localhost:8080/auth/v1
APP_URL=http://localhost:5173

GOTRUE_SMTP_HOST=smtp.example.com
GOTRUE_SMTP_PORT=587
GOTRUE_SMTP_USER=no-reply@example.com
GOTRUE_SMTP_PASS=
GOTRUE_SMTP_ADMIN_EMAIL=no-reply@example.com
GOTRUE_SMTP_SENDER_NAME=Motio
GOTRUE_EXTERNAL_KEYCLOAK_ENABLED=true
GOTRUE_EXTERNAL_KEYCLOAK_CLIENT_ID=timeline-supabase
GOTRUE_EXTERNAL_KEYCLOAK_SECRET=timeline-supabase-local-dev-secret
# Internal URL for auth container.
GOTRUE_EXTERNAL_KEYCLOAK_URL=http://keycloak:8080/realms/timeline
GOTRUE_EXTERNAL_KEYCLOAK_SCOPE=openid profile email
GOTRUE_EXTERNAL_KEYCLOAK_SCOPES=openid profile email
GOTRUE_EXTERNAL_KEYCLOAK_REDIRECT_URI=http://localhost:8080/auth/v1/callback

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak
KEYCLOAK_INTERNAL_URL=http://keycloak:8080
KEYCLOAK_PUBLIC_URL=http://localhost:8081
KEYCLOAK_HOSTNAME_STRICT=true
KEYCLOAK_REALM=timeline
KEYCLOAK_ADMIN_REALM=master
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_APP_CLIENT_ID=timeline-supabase
KEYCLOAK_REALM_DISPLAY_NAME=Motio
KEYCLOAK_REALM_DISPLAY_NAME_HTML=<strong>Motio</strong>
KEYCLOAK_REALM_EMAIL_THEME=timeline
KEYCLOAK_REALM_REMEMBER_ME=true
KEYCLOAK_REALM_SSO_SESSION_IDLE_TIMEOUT=1800
KEYCLOAK_REALM_SSO_SESSION_MAX_LIFESPAN=36000
KEYCLOAK_REALM_SSO_SESSION_IDLE_TIMEOUT_REMEMBER_ME=86400
KEYCLOAK_REALM_SSO_SESSION_MAX_LIFESPAN_REMEMBER_ME=604800
KEYCLOAK_ADMIN_BASE_URL=http://127.0.0.1:8081
KEYCLOAK_MANAGED_CLIENT_IDS=timeline-supabase
KEYCLOAK_REALM_AUDIT_FILE=infra/keycloak/realm/timeline-realm.prod.json
KEYCLOAK_REALM_AUDIT_ENABLED=true
KEYCLOAK_REALM_AUDIT_FAIL_ON_DRIFT=false
OAUTH2_PROXY_SKIP_OIDC_DISCOVERY=true
OAUTH2_PROXY_OIDC_ISSUER_URL=http://localhost:8081/realms/timeline
OAUTH2_PROXY_LOGIN_URL=http://localhost:8081/realms/timeline/protocol/openid-connect/auth?prompt=login
OAUTH2_PROXY_REDEEM_URL=http://keycloak:8080/realms/timeline/protocol/openid-connect/token
OAUTH2_PROXY_PROFILE_URL=http://keycloak:8080/realms/timeline/protocol/openid-connect/userinfo
OAUTH2_PROXY_OIDC_JWKS_URL=http://keycloak:8080/realms/timeline/protocol/openid-connect/certs
OAUTH2_PROXY_CLIENT_ID=timeline-supabase
OAUTH2_PROXY_CLIENT_SECRET=timeline-supabase-local-dev-secret
OAUTH2_PROXY_REDIRECT_URL=http://localhost:5173/oauth2/callback
OAUTH2_PROXY_SCOPE=openid profile email
OAUTH2_PROXY_EMAIL_DOMAINS=*
# oauth2-proxy performs upstream IdP logout with id_token_hint before redirecting browser back to app.
OAUTH2_PROXY_BACKEND_LOGOUT_URL=http://keycloak:8080/realms/timeline/protocol/openid-connect/logout?id_token_hint={id_token}
# Allow redirects from /oauth2/sign_out back to app auth page.
OAUTH2_PROXY_WHITELIST_DOMAINS=localhost:8081,127.0.0.1:8081,host.docker.internal:8081,motio.nikog.net
OAUTH2_PROXY_INSECURE_OIDC_ALLOW_UNVERIFIED_EMAIL=false
OAUTH2_PROXY_COOKIE_SECRET=
OAUTH2_PROXY_COOKIE_SECURE=false
OAUTH2_PROXY_COOKIE_SAMESITE=lax
OAUTH2_PROXY_COOKIE_EXPIRE=168h

RESERVE_ADMIN_EMAIL=
RESERVE_ADMIN_PASSWORD=

PGRST_DB_URI=postgresql://postgres:postgres@db:5432/postgres
GOTRUE_DB_DATABASE_URL=postgresql://postgres:postgres@db:5432/postgres?search_path=auth
SUPABASE_DB_URL=postgresql://postgres:postgres@db:5432/postgres
BACKUP_RESTORE_DB_URL=
BACKUP_AUTH_DB_USER=
BACKUP_AUTH_HOST=auth
SUPABASE_INTERNAL_URL=http://gateway:8080

VITE_SUPABASE_URL=http://localhost:8080
VITE_SUPABASE_ANON_KEY=
VITE_RESERVE_ADMIN_EMAIL=
VITE_AUTH_MODE=keycloak
VITE_KEYCLOAK_PUBLIC_URL=http://localhost:8081
VITE_KEYCLOAK_REALM=timeline
VITE_KEYCLOAK_CLIENT_ID=timeline-supabase
VITE_OAUTH2_PROXY_ENABLED=true
VITE_OAUTH2_PROXY_SIGN_OUT_PATH=/oauth2/sign_out
VITE_GA_MEASUREMENT_ID=

BACKUP_CRON=0 3 * * *
BACKUP_RETENTION_COUNT=30
BACKUP_SCHEMAS=public,auth,storage
BACKUP_MAX_UPLOAD_MB=1024
BACKUP_CORS_ORIGIN=http://localhost:5173
AUTO_PRE_MIGRATION_BACKUP=true
AUTO_KEYCLOAK_PRE_SYNC_BACKUP=true
LIQUIBASE_LOG_LEVEL=info
MIGRATION_MAX_WAIT_SECONDS=300
TASK_MEDIA_MAX_FILE_BYTES=5242880
TASK_MEDIA_USER_QUOTA_BYTES=209715200
TASK_MEDIA_WORKSPACE_QUOTA_BYTES=2147483648
TASK_MEDIA_TOKEN_TTL_SECONDS=604800
