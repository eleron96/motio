test.motio.nikog.net {
  header Strict-Transport-Security "max-age=31536000; includeSubDomains"

  route {
    encode zstd gzip

    redir /realms /realms/timeline/account 302
    redir /realms/ /realms/timeline/account 302
    redir /realms/master /realms/master/account 302
    redir /realms/master/ /realms/master/account 302
    redir /realms/timeline /realms/timeline/account 302
    redir /realms/timeline/ /realms/timeline/account 302
    redir /admin /admin/master/console/ 302
    redir /admin/master/console /admin/master/console/ 302

    handle /resources* {
      reverse_proxy keycloak:8080
    }

    handle /realms* {
      reverse_proxy keycloak:8080
    }

    handle /admin* {
      reverse_proxy keycloak:8080
    }

    handle /js* {
      reverse_proxy keycloak:8080
    }

    handle /.well-known* {
      reverse_proxy keycloak:8080
    }

    handle /health {
      reverse_proxy gateway:8080
    }

    handle /auth/v1* {
      reverse_proxy gateway:8080
    }

    handle /auth* {
      reverse_proxy web:80
    }

    handle /rest/v1* {
      reverse_proxy gateway:8080
    }

    handle /realtime/v1* {
      reverse_proxy gateway:8080
    }

    handle /storage/v1* {
      reverse_proxy gateway:8080
    }

    handle /functions/v1* {
      reverse_proxy gateway:8080
    }

    handle /backup* {
      reverse_proxy gateway:8080
    }

    handle /assets* {
      reverse_proxy web:80
    }

    handle /branding* {
      reverse_proxy web:80
    }

    handle /favicon* {
      reverse_proxy web:80
    }

    handle /logo.png {
      reverse_proxy web:80
    }

    handle /placeholder.svg {
      reverse_proxy web:80
    }

    handle /robots.txt {
      reverse_proxy web:80
    }

    handle /sitemap.xml {
      reverse_proxy web:80
    }

    handle /invite* {
      reverse_proxy web:80
    }

    handle /app* {
      reverse_proxy web:80
    }

    handle / {
      reverse_proxy web:80
    }

    handle {
      reverse_proxy oauth2-proxy:4180
    }
  }
}

:80 {
  respond 404
}
