{
  "realm": "timeline",
  "enabled": true,
  "sslRequired": "external",
  "displayName": "Motio",
  "displayNameHtml": "<strong>Motio</strong>",
  "emailTheme": "timeline",
  "loginTheme": "timeline",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "editUsernameAllowed": false,
  "verifyEmail": true,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "ssoSessionIdleTimeoutRememberMe": 86400,
  "ssoSessionMaxLifespanRememberMe": 604800,
  "internationalizationEnabled": true,
  "supportedLocales": [
    "en",
    "ru"
  ],
  "defaultLocale": "en",
  "clients": [
    {
      "clientId": "timeline-supabase",
      "name": "Timeline Supabase",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "attributes": {
        "post.logout.redirect.uris": "https://motio.nikog.net/*"
      },
      "rootUrl": "https://motio.nikog.net",
      "baseUrl": "https://motio.nikog.net",
      "redirectUris": [
        "https://motio.nikog.net/*",
        "https://motio.nikog.net/auth",
        "https://motio.nikog.net/auth/v1/callback",
        "https://motio.nikog.net/oauth2/callback"
      ],
      "webOrigins": [
        "https://motio.nikog.net"
      ]
    }
  ]
}
